# Copy this file to .env and replace values for your host.

GATEWAY_HOST=0.0.0.0
GATEWAY_HTTP_PORT=9090
GATEWAY_LOKI_HTTP_PORT=9092
GATEWAY_PROMETHEUS_HTTP_PORT=9091

GATEWAY_CONTAINER_NAME=llm-gateway
GATEWAY_VALKEY_CONTAINER_NAME=llm-gateway-valkey
GATEWAY_VALKEY_IMAGE=valkey/valkey:9.0-alpine
GATEWAY_LOKI_CONTAINER_NAME=llm-gateway-loki
GATEWAY_LOKI_IMAGE=grafana/loki:3.7.1
GATEWAY_PROMETHEUS_CONTAINER_NAME=llm-prometheus
GATEWAY_PROMETHEUS_IMAGE=prom/prometheus:latest
GATEWAY_NODE_EXPORTER_CONTAINER_NAME=llm-node-exporter
GATEWAY_NODE_EXPORTER_IMAGE=prom/node-exporter:latest
GATEWAY_DCGM_EXPORTER_CONTAINER_NAME=llm-dcgm-exporter
GATEWAY_DCGM_EXPORTER_IMAGE=nvidia/dcgm-exporter:latest

GATEWAY_BACKEND_BASE_URL=http://backend:8000
GATEWAY_ENABLE_MAX_COMPLETION_TOKENS_OVERRIDE=true
GATEWAY_FORCED_MAX_COMPLETION_TOKENS=1024
GATEWAY_ENV=local
GATEWAY_REQUEST_LOG_LABEL=llm-gateway
GATEWAY_TIMEOUT_CONNECT_SEC=30
GATEWAY_TIMEOUT_READ_SEC=1800
GATEWAY_TIMEOUT_WRITE_SEC=1800
GATEWAY_TIMEOUT_POOL_SEC=30
GATEWAY_HTTP_MAX_CONNECTIONS=200
GATEWAY_HTTP_MAX_KEEPALIVE_CONNECTIONS=100
GATEWAY_LOG_BODY_SHA256=false

GATEWAY_LOKI_ENABLED=true
GATEWAY_LOKI_PUSH_URL=http://llm-gateway-loki:3100/loki/api/v1/push
GATEWAY_LOKI_BATCH_SIZE=200
GATEWAY_LOKI_FLUSH_INTERVAL_SEC=1.0
GATEWAY_LOKI_QUEUE_MAX_SIZE=10000

GATEWAY_OTEL_ENABLED=true
GATEWAY_OTEL_SERVICE_NAME=llm-gateway
GATEWAY_OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4317
GATEWAY_OTEL_EXPORTER_OTLP_PROTOCOL=grpc
GATEWAY_OTEL_SAMPLE_RATIO=1.0
GATEWAY_OTEL_FASTAPI_EXCLUDED_URLS=/gateway/metrics,/healthz,/$

GATEWAY_SESSION_VALKEY_URL=redis://llm-gateway-valkey:6379/0
GATEWAY_SESSION_KEY_PREFIX=llm-gateway:session:
GATEWAY_SESSION_TTL=21600
GATEWAY_SESSION_TRACKER_MAX_CONNECTIONS=256

GATEWAY_VLLM_BACKEND_BASE_URL=http://vllm:8000
GATEWAY_VLLM_IMAGE=vllm/vllm-openai:v0.19.0
GATEWAY_VLLM_CONTAINER_NAME=vllm
GATEWAY_VLLM_MODEL_PATH=/path/to/local/hf/model

GATEWAY_SGLANG_BACKEND_BASE_URL=http://sglang:30000
GATEWAY_SGLANG_IMAGE=lmsysorg/sglang:v0.5.11
GATEWAY_SGLANG_CONTAINER_NAME=sglang
GATEWAY_SGLANG_MODEL_PATH=/path/to/local/hf/model
GATEWAY_SGLANG_HTTP_PORT=9900
GATEWAY_SGLANG_SHM_SIZE=32gb

GATEWAY_TEMPO_IMAGE=grafana/tempo:2.9.1
GATEWAY_TEMPO_CONTAINER_NAME=llm-gateway-tempo
GATEWAY_TEMPO_HTTP_PORT=3200
GATEWAY_OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.152.0
GATEWAY_OTEL_COLLECTOR_CONTAINER_NAME=llm-gateway-otel-collector
GATEWAY_OTEL_GRPC_PORT=4317
GATEWAY_OTEL_HTTP_PORT=4318
GATEWAY_OTEL_HEALTH_PORT=13133
GATEWAY_GRAFANA_IMAGE=grafana/grafana:12.3.0
GATEWAY_GRAFANA_CONTAINER_NAME=llm-gateway-grafana
GATEWAY_GRAFANA_HTTP_PORT=3000
GATEWAY_GRAFANA_ADMIN_USER=admin
GATEWAY_GRAFANA_ADMIN_PASSWORD=admin
