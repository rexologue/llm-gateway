# Copy this file to .env and replace values for your host.

#############################
# Compose interpolation     #
#############################

# LLM API binding. The gateway defaults to calling this through
# host.docker.gateway:9900 from its own compose stack.
LLM_HOST=127.0.0.1
LLM_HTTP_PORT=9900

# LLM-side Prometheus. It scrapes only backend, node, and GPU metrics.
LLM_PROMETHEUS_HOST=0.0.0.0
LLM_PROMETHEUS_HTTP_PORT=9191
LLM_PROMETHEUS_IMAGE=prom/prometheus:latest
LLM_PROMETHEUS_CONTAINER_NAME=llm-prometheus

# Host and GPU exporters.
LLM_NODE_EXPORTER_IMAGE=prom/node-exporter:latest
LLM_NODE_EXPORTER_CONTAINER_NAME=llm-node-exporter
LLM_DCGM_EXPORTER_IMAGE=nvidia/dcgm-exporter:latest
LLM_DCGM_EXPORTER_CONTAINER_NAME=llm-dcgm-exporter

# vLLM backend variant.
LLM_VLLM_IMAGE=vllm/vllm-openai:v0.19.0
LLM_VLLM_CONTAINER_NAME=vllm
LLM_VLLM_MODEL_PATH=/path/to/local/hf/model

# SGLang backend variant.
LLM_SGLANG_IMAGE=lmsysorg/sglang:v0.5.11
LLM_SGLANG_CONTAINER_NAME=sglang
LLM_SGLANG_MODEL_PATH=/path/to/local/hf/model
LLM_SGLANG_SHM_SIZE=32gb

#############################
# Container environment     #
#############################

# Smoke test runner. Used only by llm-smoke-tests with --profile test.
SMOKE_MODEL=local-model
SMOKE_PROMPT=Say pong in one short sentence.
SMOKE_TIMEOUT_SEC=60
SMOKE_API_KEY=
SMOKE_CHECK_TOOLS=false
