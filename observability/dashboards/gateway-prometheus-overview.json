{
  "uid": "llm-gateway-prometheus-overview",
  "title": "Gateway / Prometheus Overview",
  "tags": [
    "llm-gateway",
    "gateway",
    "prometheus"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "label": "Prometheus datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "route",
        "type": "query",
        "label": "route",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(gateway_requests_total, route)",
        "query": {
          "qryType": 1,
          "query": "label_values(gateway_requests_total, route)",
          "refId": "Prometheus-route"
        },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "model",
        "type": "query",
        "label": "model",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(gateway_request_e2e_seconds_count, model)",
        "query": {
          "qryType": 1,
          "query": "label_values(gateway_request_e2e_seconds_count, model)",
          "refId": "Prometheus-model"
        },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "stream",
        "type": "custom",
        "label": "stream",
        "query": "true,false",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "result",
        "type": "custom",
        "label": "result",
        "query": "success,error,cancelled",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "status_family",
        "type": "custom",
        "label": "status_family",
        "query": "2xx,4xx,5xx,unknown",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "session_first_request",
        "type": "custom",
        "label": "session first request",
        "query": "true,false",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
