          "expr": "histogram_quantile(0.99, sum by (le) (rate(gateway_request_e2e_seconds_bucket{route=~\"$route\",model=~\"$model\",stream=~\"$stream\",result=~\"$result\",status_family=~\"$status_family\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "range": true,
          "editorMode": "code"
        }
      ],
      "options": {}
