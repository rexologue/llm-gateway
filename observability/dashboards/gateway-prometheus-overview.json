      "title": "TTFT Quantiles",
      "description": "Streaming time-to-first-token quantiles. Empty for non-streaming requests because no TTFT is observed there.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
