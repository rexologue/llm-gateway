      "options": {}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "E2E Quantiles",
      "description": "Gateway end-to-end latency quantiles for all accepted gateway requests.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
