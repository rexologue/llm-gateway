      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route, stream) (rate(gateway_requests_total{route=~\"$route\",stream=~\"$stream\"}[$__rate_interval]))",
          "legendFormat": "{{route}} stream={{stream}}",
          "range": true,
          "editorMode": "code"
        }
      ],
      "options": {}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Response Outcomes",
      "description": "Terminal response rate by HTTP status family and gateway result classification.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
