      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_family, result) (rate(gateway_responses_total{route=~\"$route\",stream=~\"$stream\",result=~\"$result\",status_family=~\"$status_family\"}[$__rate_interval]))",
          "legendFormat": "{{status_family}} {{result}}",
          "range": true,
          "editorMode": "code"
        }
